{
  "name": "evanschoffstall.me",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "contentlayer:build": "node ./scripts/contentlayer-build.cjs",
    "contentlayer:dev": "bunx --bun contentlayer dev",
    "readmes:download": "tsx ./scripts/download-project-readmes.ts",
    "dev": "bun run contentlayer:build && next dev --turbopack",
    "dev:local": "bun run contentlayer:build && next dev --turbopack -H 0.0.0.0 -p 3000",
    "build": "next build",
    "clean": "rm -rf .next .cache .contentlayer",
    "types": "tsc --noEmit",
    "start": "next start"
  },
  "dependencies": {
    "@upstash/redis": "^1.36.2",
    "contentlayer": "^0.3.4",
    "framer-motion": "^12.34.0",
    "github-markdown-css": "^5.9.0",
    "lucide-react": "^0.563.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.1",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "3.0.1",
    "shiki": "^1.0.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.24",
    "postcss": "^8.5.6",
    "postcss-nesting": "^14.0.0",
    "tailwindcss": "^3",
    "tailwindcss-debug-screens": "2.2.1",
    "tsx": "^4.20.4",
    "typescript": "^5.9.3"
  }
}
