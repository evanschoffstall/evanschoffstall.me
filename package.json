    "picomatch": "4.0.4",
    "uuid": "14.0.0",
    "yaml": "2.8.3"
  },
  "private": true,
  "scripts": {
    "build": "node ./scripts/contentlayer-build.mjs && next build",
    "build:playwright": "rm -rf .next-playwright/build .next-playwright/cache .next-playwright/trace-build && env NEXT_DIST_DIR=.next-playwright node ./scripts/contentlayer-build.mjs && env NEXT_DIST_DIR=.next-playwright next build --webpack",
    "check": "check-suite",
    "check:duplicates": "bunx jscpd --config .jscpd.json",
    "check:gitleaks": "bunx @0xts/gitleaks-cli detect -s src --no-git -c .gitleaks.toml",
    "check:secretlint": "secretlint '**/*' --secretlintignore .secretlintignore",
    "check:tsd": "bunx tsd --typings next-env.d.ts --files next-env.test-d.ts",
    "check:type-coverage": "bunx type-coverage --at-least 98 --cache --cache-directory .cache/type-coverage",
    "clean": "rm -rf .next .cache .contentlayer",
    "contentlayer:build": "node ./scripts/contentlayer-build.mjs",
    "contentlayer:dev": "bunx --bun contentlayer dev",
    "dev": "node ./scripts/contentlayer-build.mjs && next dev --turbopack",
    "dev:playwright": "env NEXT_DIST_DIR=.next-playwright node ./scripts/contentlayer-build.mjs && env NEXT_DIST_DIR=.next-playwright next dev --webpack -H 127.0.0.1 -p 3100",
    "readmes:download": "tsx ./scripts/download-project-readmes.ts",
    "start:playwright": "NEXT_DIST_DIR=.next-playwright next start -p 3100",
    "start": "next start",
    "test:e2e:coverage": "PLAYWRIGHT_COVERAGE_ENABLED=1 PLAYWRIGHT_JUNIT_OUTPUT_FILE=coverage/playwright-junit.xml tsx ./scripts/run-playwright.ts",
    "test:e2e": "tsx ./scripts/run-playwright.ts",
    "types": "tsc --noEmit"
  },
  "version": "0.1.0"
}
